@{
    var appName = System.Configuration.ConfigurationManager.AppSettings["AppName"] ?? "Default App";
    var author = System.Configuration.ConfigurationManager.AppSettings["Author"] ?? "";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - @appName</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="text-bg-dark text-center py-2">
            @Html.ActionLink(@appName, "Index", "Home", new { area = "" }, new { @class = "fs-2 text-decoration-none text-white" })
    </div>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - @author - @appName</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
