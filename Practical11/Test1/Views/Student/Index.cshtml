@model IEnumerable<Test1.Models.Entities.Student>

@{
    ViewBag.Title = "Home Page";
}

<main>
    <h2>
        Task:
    </h2>
    <ul>
        <li>
            Create an MVC project for the demo of CRUD functionality.
        </li>
        <li>
            The user should save the output to a static list created in the controller.
        </li>
        <li>
            The fields to be used for forms should be Name, Date of birth, Address, etc.
        </li>
        <li>
            There should be each action on the controller for create, update, delete & view.
        </li>
    </ul>

    <hr />


    <p>
        <a href="@Url.Action("Create")" class="btn btn-primary" title="Create new entry">
            <span class="bi bi-plus-lg"></span> New
        </a>
    </p>
    <table class="table">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FullName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateOfBirth)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Address)
            </th>
            <th>
                Actions
            </th>
        </tr>

        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.FullName)
                    </td>
                    <td>
                        @item.DateOfBirth.ToString("dd/MM/yyyy")
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Address)
                    </td>
                    <td>
                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-warning" title="Edit Entry">
                            <span class="bi bi-pen-fill"></span>
                        </a>
                        <a href="@Url.Action("Delete", new { id = item.Id })"
                           class="btn btn-danger"
                           title="Delete Entry"
                           onclick="return confirm('Are you sure you want to delete this entry?')">
                            <span class="bi bi-trash-fill"></span>
                        </a>
                    </td>
                </tr>
            }
        }

    </table>

</main>
