@model IEnumerable<Test3.Models.Entities.Employee>

<h2>Employees by Designation</h2>

@using (Ajax.BeginForm("ByDesignation", "Employee", new AjaxOptions { HttpMethod = "POST", UpdateTargetId = "output"}))
{
    <div class="d-flex gap-2 mb-3">
        @Html.DropDownList("designationId",
                 (SelectList)ViewBag.Designations,
                 "Select Designation",
                 new { @class = "form-select w-auto" })
        <button type="submit" class="btn btn-primary">Filter</button>
    </div>
}

@if (Model != null && Model.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>First Name</th>
                <th>Middle Name</th>
                <th>Last Name</th>
                <th>DOB</th>
                <th>Mobile</th>
                <th>Address</th>
                <th>Salary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FirstName</td>
                    <td>@(item.MiddleName ?? "-")</td>
                    <td>@item.LastName</td>
                    <td>@item.DOB.ToString("dd MMM yyyy")</td>
                    <td>@item.MobileNumber</td>
                    <td>@(item.Address ?? "-")</td>
                    <td>@item.Salary.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No employees found for selected designation.</p>
}