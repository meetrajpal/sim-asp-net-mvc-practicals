@{
    var appName = System.Configuration.ConfigurationManager.AppSettings["AppName"] ?? "Default App";
    var author = System.Configuration.ConfigurationManager.AppSettings["Author"] ?? "";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - @appName</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
</head>
<body>
    <div class="container-fluid text-bg-dark">
        <div class=" d-flex justify-content-between py-2 align-items-center">
            @Html.ActionLink(@appName, "Index", "Home", new { area = "" }, new { @class = "fs-2 text-decoration-none text-white" })
            @if (Request.IsAuthenticated)
            {
                <div>
                    <span class="navbar-text me-2">Hello, @User.Identity.Name</span>
                    <a href="@Url.Action("Logout", "Auth")" class="btn btn-sm btn-outline-danger">Logout</a>
                </div>
            }
        </div>
    </div>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - @author - @appName</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
